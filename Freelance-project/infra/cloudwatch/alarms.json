    "Namespace": "AWS/RDS",
    "Statistic": "Average",
    "Period": 300,
    "EvaluationPeriods": 2,
    "Threshold": 10737418240,
    "ComparisonOperator": "LessThanThreshold",
    "TreatMissingData": "breaching",
    "Dimensions": [
      {
        "Name": "DBInstanceIdentifier",
